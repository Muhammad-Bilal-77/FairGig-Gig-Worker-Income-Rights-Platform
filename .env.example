# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fairgig
POSTGRES_SUPERUSER=fairgig_admin
POSTGRES_SUPERUSER_PASSWORD=fairgig_admin_secret_2026

# Service-specific DB users (created in 01_schemas.sql)
AUTH_DB_USER=auth_svc
AUTH_DB_PASSWORD=auth_svc_secret_2026
AUTH_DB_URL=postgresql://auth_svc:auth_svc_secret_2026@localhost:5432/fairgig

EARNINGS_DB_USER=earnings_svc
EARNINGS_DB_PASSWORD=earnings_svc_secret_2026
EARNINGS_DB_URL=postgresql://earnings_svc:earnings_svc_secret_2026@localhost:5432/fairgig

GRIEVANCE_DB_USER=grievance_svc
GRIEVANCE_DB_PASSWORD=grievance_svc_secret_2026
GRIEVANCE_DB_URL=postgresql://grievance_svc:grievance_svc_secret_2026@localhost:5432/fairgig

ANALYTICS_DB_USER=analytics_svc
ANALYTICS_DB_PASSWORD=analytics_svc_secret_2026
ANALYTICS_DB_URL=postgresql://analytics_svc:analytics_svc_secret_2026@localhost:5432/fairgig

CERTIFICATE_DB_USER=certificate_svc
CERTIFICATE_DB_PASSWORD=certificate_svc_secret_2026
CERTIFICATE_DB_URL=postgresql://certificate_svc:certificate_svc_secret_2026@localhost:5432/fairgig

# Read-only user for cross-schema analytics queries
READONLY_DB_USER=readonly_svc
READONLY_DB_PASSWORD=readonly_svc_secret_2026
READONLY_DB_URL=postgresql://readonly_svc:readonly_svc_secret_2026@localhost:5432/fairgig

# ── Redis ──────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ── JWT ────────────────────────────────────────────────────
JWT_ACCESS_SECRET=fairgig_access_secret_min_32_chars_change_in_prod
JWT_REFRESH_SECRET=fairgig_refresh_secret_min_32_chars_change_in_prod
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Cloudinary (screenshot uploads) ───────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Service ports ──────────────────────────────────────────
AUTH_PORT=4001
EARNINGS_PORT=4002
ANOMALY_PORT=4003
GRIEVANCE_PORT=4004
ANALYTICS_PORT=4005
CERTIFICATE_PORT=4006
FRONTEND_PORT=3000

# ── Inter-service URLs (used when HTTP calls are needed) ───
AUTH_SERVICE_URL=http://localhost:4001
EARNINGS_SERVICE_URL=http://localhost:4002
ANOMALY_SERVICE_URL=http://localhost:4003
GRIEVANCE_SERVICE_URL=http://localhost:4004
ANALYTICS_SERVICE_URL=http://localhost:4005
CERTIFICATE_SERVICE_URL=http://localhost:4006

# ── Environment ────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
