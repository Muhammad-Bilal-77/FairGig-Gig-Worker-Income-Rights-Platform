# Auth service reads from the ROOT .env at fairgig/.env
# This file documents which variables the auth service uses.
# Do NOT create a separate .env here.

AUTH_DB_URL=postgresql://auth_svc:auth_svc_secret_2026@localhost:5432/fairgig
JWT_ACCESS_SECRET=fairgig_access_secret_min_32_chars_change_in_prod
JWT_REFRESH_SECRET=fairgig_refresh_secret_min_32_chars_change_in_prod
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
AUTH_PORT=4001
NODE_ENV=development
LOG_LEVEL=info
